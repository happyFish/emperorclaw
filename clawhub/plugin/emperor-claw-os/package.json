{
  "name": "@malecu/emperor-claw-os-plugin",
  "version": "0.1.9",
  "private": false,
  "type": "module",
  "description": "Native OpenClaw plugin for Emperor bridge installation and agent lifecycle management",
  "author": "Jose Zuma",
  "homepage": "https://github.com/josezuma/emperorclaw/tree/main/clawhub/plugin/emperor-claw-os",
  "repository": {
    "type": "git",
    "url": "https://github.com/josezuma/emperorclaw.git",
    "directory": "clawhub/plugin/emperor-claw-os"
  },
  "bugs": {
    "url": "https://github.com/josezuma/emperorclaw/issues"
  },
  "files": [
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "dist",
    "index.ts",
    "openclaw.plugin.json",
    "README.md",
    "session-key-api.ts",
    "setup-entry.ts",
    "tsconfig.json",
    "runtime",
    "scripts",
    "src",
    "types",
    "references"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "validate:local": "bash scripts/validate-local.sh"
  },
  "openclaw": {
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.3.31",
      "pluginSdkVersion": "2026.3.31"
    },
    "extensions": [
      "./index.ts"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ],
    "channel": {
      "id": "emperor-claw-os",
      "label": "Emperor",
      "blurb": "Connect OpenClaw to Emperor thread messaging."
    },
    "install": {
      "localPath": "./",
      "defaultChoice": "local"
    }
  },
  "keywords": [
    "openclaw",
    "plugin",
    "emperor",
    "bridge",
    "agents",
    "channel"
  ],
  "license": "MIT"
}
