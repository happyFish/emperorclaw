{
  "name": "@malecu/emperor-claw-os-plugin",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Native OpenClaw plugin for Emperor bridge installation and agent lifecycle management",
  "openclaw": {
    "compat": {
      "pluginApi": "*"
    },
    "build": {
      "openclawVersion": "2026.3.31"
    },
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "emperor-claw-os",
      "label": "Emperor",
      "blurb": "Connect OpenClaw to Emperor thread messaging."
    },
    "install": {
      "localPath": "./",
      "defaultChoice": "local"
    }
  },
  "keywords": [
    "openclaw",
    "plugin",
    "emperor",
    "bridge",
    "agents",
    "channel"
  ],
  "license": "MIT"
}
